// =============================================================================
// spatial-cardiopharyngeal/nextflow.config
// =============================================================================

params {
  // --- inputs / outputs ---
  input_samples = "${projectDir}/params/samples.yml"
  raw_data_dir  = "${projectDir}/data"
  results_dir   = "${projectDir}/results"

  // --- Spatial Defaults ---
  n_hvgs        = 2000
  spatial_genes = "Ttn,Foxf1,Nkx2-5,Myh6" // Cardiopharyngeal markers to plot
  
  // --- Reproducibility ---
  seed = 42
}

// Default process resources
process {
  cpus   = 2
  memory = 16.GB
  withName: 'SEURAT_SPATIAL'   { memory = 32.GB } // SeuratDisk conversion is RAM-heavy
  withName: 'SQUIDPY_TOPOLOGY' { memory = 24.GB }
}

// --- Execution profiles ---
profiles {
  standard { /* local execution */ }

  docker {
    docker.enabled    = true
    docker.runOptions = '-u $(id -u):$(id -g)'
    process.container = 'gideondocker98/spatial-omics:latest'
  }

  apple_silicon {
    process.maxForks = 2
    process { withName: 'SEURAT_SPATIAL' { memory = 24.GB } }
  }

  hpc {
    process.executor = 'slurm'
    process.queue    = 'main'
    process { cpus = 4; memory = 64.GB }
  }
}